{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Information about a researcher in the lab",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "avatarUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "masteryLevels": {
          "type": "array",
          "description": "Weekly chemistry mastery percentages"
        },
        "completedMissions": {
          "type": "array",
          "description": "IDs of completed Quantum missions (Badges)"
        },
        "atomHighscore": {
          "type": "integer",
          "description": "High score achieved in the Atom Builder lab"
        },
        "periodicHighscore": {
          "type": "integer",
          "description": "High score achieved in the Periodic Table game"
        }
      },
      "required": ["id", "name", "email", "createdAt"]
    },
    "ActivityLog": {
      "title": "Activity Log",
      "description": "A log of a student's learning activity inside the lab",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "activityType": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "score": {
          "type": "object",
          "properties": {
            "earned": { "type": "number" },
            "total": { "type": "number" }
          }
        },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "activityType", "title", "description", "timestamp"]
    },
    "PublicProfile": {
      "title": "Public Achievement Profile",
      "description": "Exposes researcher highlights for leaderboard and gamification display",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "atomHighscore": { "type": "integer" },
        "periodicHighscore": { "type": "integer" },
        "completedMissions": { "type": "array" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name"]
    },
    "PublicActivity": {
      "title": "Public Activity Ledger",
      "description": "Append-only timeline of achievements visible across the research framework",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "activityType": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "userName", "activityType", "title", "timestamp"]
    },
    "Announcement": {
      "title": "Class Announcement",
      "description": "An announcement posted by a teacher to the class dashboard",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "category": { "type": "string", "enum": ["tugas", "pengumuman", "materi"] },
        "authorName": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "content", "category", "authorName", "timestamp"]
    },
    "Flashcard": {
      "title": "Custom Anki Flashcard",
      "description": "User created flashcard stored in cloud for persistent learning across devices",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "category": { "type": "string" },
        "question": { "type": "string" },
        "answer": { "type": "string" },
        "hint": { "type": "string" }
      },
      "required": ["id", "category", "question", "answer"]
    },
    "Classroom": {
      "title": "Classroom Group",
      "description": "A study group or class created by a teacher",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "className": { "type": "string" },
        "teacherId": { "type": "string" },
        "teacherName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["code", "className", "teacherId", "teacherName", "createdAt"]
    },
    "StudentReport": {
      "title": "Submitted Student Lab Report",
      "description": "A lab report submitted by a student for teacher grading and feedback",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "studentId": { "type": "string" },
        "studentName": { "type": "string" },
        "studentClass": { "type": "string" },
        "topicId": { "type": "string" },
        "topicTitle": { "type": "string" },
        "objectives": { "type": "string" },
        "theory": { "type": "string" },
        "apparatus": { "type": "string" },
        "observations": { "type": "array" },
        "conclusion": { "type": "string" },
        "submittedAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "graded"] },
        "grade": { "type": "number" },
        "teacherFeedback": { "type": "string" },
        "gradedAt": { "type": "string", "format": "date-time" },
        "teacherName": { "type": "string" }
      },
      "required": ["id", "studentId", "studentName", "studentClass", "topicId", "topicTitle", "objectives", "theory", "apparatus", "observations", "conclusion", "submittedAt", "status"]
    },
    "VerifiedBadge": {
      "title": "Verified Badge Credential",
      "description": "A badge claim signed and verified cryptographically by the server",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "badgeId": { "type": "string" },
        "points": { "type": "integer" },
        "timestamp": { "type": "integer" },
        "signature": { "type": "string" }
      },
      "required": ["id", "userId", "badgeId", "points", "timestamp", "signature"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Stores profile details and mastery statistics"
    },
    "users/{userId}/verified_badges/{badgeId}": {
      "schema": "VerifiedBadge",
      "description": "Cryptographically signed badge achievements verified on database"
    },
    "users/{userId}/activities/{activityId}": {
      "schema": "ActivityLog",
      "description": "Chronological history of learning events and quiz completions"
    },
    "users/{userId}/flashcards/{flashcardId}": {
      "schema": "Flashcard",
      "description": "Custom flashcards built inside the Anki interface by this researcher"
    },
    "public_profiles/{userId}": {
      "schema": "PublicProfile",
      "description": "Exposed profile scores used in global ranking lists"
    },
    "public_activities/{activityId}": {
      "schema": "PublicActivity",
      "description": "Global realtime log tracker for other students to explore ongoing efforts"
    },
    "class_announcements/{announcementId}": {
      "schema": "Announcement",
      "description": "Class announcements and tasks shared by teachers/instructors"
    },
    "classrooms/{classroomId}": {
      "schema": "Classroom",
      "description": "Classrooms created by teachers for managing study groups"
    },
    "student_reports/{reportId}": {
      "schema": "StudentReport",
      "description": "Submissions of virtual lab reports for teacher review and grading"
    }
  }
}
